{
  "name": "meshy-mcp-server",
  "version": "1.2.4",
  "description": "MCP server for Meshy.ai 3D model generation API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "meshy-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "meshy",
    "3d",
    "ai",
    "model-generation"
  ],
  "author": "gwizards",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gwizards/meshy-mcp-server.git"
  },
  "homepage": "https://github.com/gwizards/meshy-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/gwizards/meshy-mcp-server/issues"
  },
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
